# TAM Capital Research Platform - Environment Variables

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Security
SECRET_KEY=generate-a-strong-random-key-here

# Database (set automatically in Docker, only needed for local dev)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tam_research

# Redis (set automatically in Docker, only needed for local dev)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
